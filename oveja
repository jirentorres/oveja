        		"vlc")
    				vlc --http-user-agent="$user_agent" "$index_link" &>/dev/null &
        		;;
    			"ffplay")
    				ffplay -headers "User-Agent: $user_agent"$'\r\n' "$index_link" &>/dev/null &
    			;;
    			*)
    				echo -e "${red}$play no esta soportado${def}"; exit 4
    			;;
    		esac
			echo -e "${bold}Reproduciendo...${def}"; sleep 1.2
			anime_options "$1" "$2" "$3" "$4" "$5" "$6" "$index_link"
			exit 0
		;;
		"UPNShare" | "1Fichier")
			echo -e "${bold}UPNShare/1Fichier${def} no esta soportado para descarga directa ni reproduccion directa, debes descargarlo/verlo desde su propia pagina.\nDeseas abrir tu Browser por defecto con este link? -> ${bold}$2${def}"
			abrir_navegador=$(echo -e "Si\nNo" | fzf --height 5)
			if [ "$abrir_navegador" == "Si" ]; then xdg-open "$2"; fi
			anime_options "$1" "$2" "$3" "$4" "$5" "$6" "0"
			exit 0
		;;
		"Unknown")
			echo -e "Deseas abrir tu Browser por defecto con este link? -> ${bold}$2${def}"
			abrir_navegador=$(echo -e "Si\nNo" | fzf --height 5)
			if [ "$abrir_navegador" == "Si" ]; then xdg-open "$2"; fi
			anime_options "$1" "$2" "$3" "$4" "$5" "$6" "0"
			exit 0
		;;
		*)
			echo -e "${red}Este mirror no ha sido agregado, verifica posibles actualizaciones en Github o abre un issue.${def}"
			echo -e "Log:\nMirror: $1\nUrl: $2\nFrontend: $6"
			exit 4
		;;
	esac
	echo -e "${red}Error en mirror!${def}"
	exit 3
}

