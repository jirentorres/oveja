		;;
		"SaveFiles")
			file_code=${2##*/}
			referer=${2%/e/*}
			master_link=$(curl -s "$referer/dl" -X POST -H "User-Agent: $user_agent" --data-binary "op=embed&file_code=${file_code}&auto=1&referer=" | grep "master" | awk '{print $2}' FS='"')
