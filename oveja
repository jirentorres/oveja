function read_logs(){
	cat $HOME/.config/oveja/logs.txt | fzf --reverse --cycle --prompt "Selecciona un anime para continuar: "
	echo -e "${bold}Funcion de logs pronto... 🐑${def}"
	exit 0
}

function continuar_anime(){
	tail -n1 $HOME/.config/oveja/logs.txt
	echo -e "${bold}Funcion de continuar anime pronto... 🐑 ${def}"
	exit 0
}

while getopts ":-:clhv" opt; do
	case $opt in
		c)continuar_anime;;
		l)read_logs;;
		h)help;;
		v)echo "$version_info"; exit 0;;
		-)
			case "${OPTARG}" in
				continuar)continue_anime;;
				logs)read_logs;;
				help) help;;
				version) echo "$version_info"; exit 0;;
				*) echo -e "${red}--${OPTARG} isn't a valid flag!${def}">&2; exit 1;;
			esac;;
		?) echo -e "${red}-${OPTARG} isn't a valid flag!${def}">&2; exit 1;;
	esac
done

function main(){
	if [ ! -d /tmp/oveja/ ]; then mkdir /tmp/oveja/ &>/dev/null; fi
	if [ ! -d $HOME/.config/oveja/ ]; then mkdir $HOME/.config/oveja/ &>/dev/null; fi
	echo -e "${bold}Mee... 🐑${def}"
	echo -ne "${bold}Buscar anime: ${def}"; read raw_text
	text_query=$(echo -n "$raw_text" | perl -pe 's/([^a-zA-Z0-9\Q.-_\E])/sprintf("%%%02X", ord($1))/ge')
	search_anime "$text_query"
	exit 0
}

