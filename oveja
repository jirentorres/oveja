        		;;
        		"vlc")
    				vlc --http-referrer="https://re.ironhentai.com" --http-user-agent="$user_agent" "$index_link" &>/dev/null &
        		;;
    			"ffplay")
    				ffplay -headers "Referer: https://re.ironhentai.com"$'\r\n'"User-Agent: $user_agent"$'\r\n' "$index_link" &>/dev/null &
