#!/bin/bash

version_info="oveja 1.0.0"

#Colors
red='\e[1;31m'
bold='\e[1m'
def='\e[0m'

#User-Agent, puedes cambiarlo si lo deseas
user_agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:138.0) Gecko/20100101 Firefox/138.0"

#Reproductor (testeados: mpv, vlc, ffplay)
player="mpv"

#Directorio de descargas
dir_descargas="$HOME"

trap ctrl_c INT; function ctrl_c(){ exit 3; }

function help(){
	echo -e "${bold}Usage: oveja$def [OPTIONS]"
	echo -e "${bold}Options:$def"
	echo -e "$bold  -c, --continuar$def\tContinuar anime"
	echo -e "$bold  -l, --logs$def\t\tVer logs"
	echo -e "$bold  -h, --help$def\t\tPrint help"
	echo -e "$bold  -v, --version$def\t\tPrint version"
	exit 0
}

#Logs: anime/capitulo_visto
function read_logs(){
	anime_select=$(cat "$HOME/.config/oveja/logs.txt" | fzf --reverse --cycle --prompt "logs: ")
	watch_anime "$anime_select"
	exit 0
}

#Buscar anime
function search_anime(){
	frontend=$(echo -e "AnimeAV1\nJkAnime\nMonosChinos2\nAnimeFLV\nTioAnime" | fzf --reverse --cycle --prompt "Selecciona un Frontend: ")
	case "$frontend" in
		"AnimeAV1")
			curl -s -A "$user_agent" "https://animeav1.com/catalogo?search=$1" -o/tmp/oveja/response; wait
			cat /tmp/oveja/response | htmlq 'a.inset-0' -a href | awk '{print $NF}' FS='/' >/tmp/oveja/anime_name
			if [[ $(< /tmp/oveja/response) =~ "page=" ]]; then
				curl -s -A "$user_agent" "https://animeav1.com/catalogo?search=$1&page=2" | htmlq 'a.inset-0' -a href | awk '{print $NF}' FS='/' >>/tmp/oveja/anime_name
			fi
			anime_name=$(cat /tmp/oveja/anime_name | fzf --reverse --cycle --prompt "Selecciona un anime: ")
			anime_caps=$(curl -s -A "$user_agent" "https://animeav1.com/media/$anime_name" | grep -oP 'episodesCount:\K\d+')
			if [ $anime_caps -eq 0 ]; then
				echo "${red}Este anime no tiene ningun capitulo publicado. Verifica en MyAnimeList o Anilist para cerciorarte de esto, o reportalo como falla en github.com/user/issues/${def}"; exit 2
        	fi
        	select_cap=$(seq 1 $anime_caps | fzf --reverse --cycle --prompt "Selecciona un capitulo: ")
        	curl -s -A "$user_agent" "https://animeav1.com/media/$anime_name/$select_cap/__data.json?x-sveltekit-invalidated=0001" | jq -r '.. | strings' | awk '/^http/ {print (s?s:"Unknown"), $0; s=""} !/^http/ {s=$0}' | nl -w1 -s ' ' > /tmp/oveja/mirror
        	mirror=$(cat /tmp/oveja/mirror | fzf --reverse --cycle --prompt "Selecciona un mirror: ")
        	play_anime "$(echo $mirror | awk '{print $2}')" "$(echo $mirror | awk '{print $NF}')" "$anime_name" "$select_cap" "$anime_caps" "$frontend"
        	exit 0
		;;
    	"JkAnime")
        	anime_name=$(curl -s -A "$user_agent" "https://jkanime.net/buscar/$1" | htmlq 'div.anime__item' | htmlq a -a href | awk '!seen[$0]++' | awk '{print $4}' FS=/ | fzf --reverse --cycle --prompt "Selecciona un anime: ")
        	curl -s -A "$user_agent" "https://jkanime.net/$anime_name" -o/tmp/oveja/response; wait
        	anime_caps=$(cat /tmp/oveja/response | grep "Episodios:" -m1 | awk '{print $4}' FS='>' | awk '{print $1}' 'FS=<' | head -n1 | tr -d '[:space:]')
        	if [ $anime_caps -eq 0 ]; then
        		anime_caps=$(cat /tmp/oveja/response | grep "Último" | htmlq a -t | awk '{print $4}')
        		if [ $anime_caps -eq 0 ]; then
        			echo-e  "${red}Este anime no tiene ningun capitulo publicado. Verifica en MyAnimeList o Anilist para cerciorarte de esto, o reportalo como falla en github.com/user/issues/${def}"; exit 2
        		fi
        	fi
        	select_cap=$(seq 1 $anime_caps | fzf --reverse --cycle --prompt "Seleciona un capitulo: ")
        	curl -s -A "$user_agent" "https://jkanime.net/$anime_name/$select_cap/" -o/tmp/oveja/response; wait
        	cat /tmp/oveja/response | grep "var servers" | htmlq --text | sed 's/.$//; s/var servers = //' | jq -r '.[] | "\(.server) \(.remote | @base64d)"' | grep -v '^$' | nl -w 1 -s ' ' > /tmp/oveja/mirror
        	mirror=$(cat /tmp/oveja/mirror | fzf --reverse --cycle --prompt "Selecciona un mirror: ")
			#play_anime MIRROR LINK_MIRROR NOMBRE_ANIME CAPITULO_ANIME CAPITULOS_TOTALES FRONTEND
        	play_anime "$(echo $mirror | awk '{print $2}')" "$(echo $mirror | awk '{print $NF}')" "$anime_name" "$select_cap" "$anime_caps" "$frontend"
        	exit 0
        ;;
    	"MonosChinos2")
			curl -s -A "$user_agent" "https://monoschino2.com/directorio/anime?q=$1" -o/tmp/oveja/response; wait
			cat /tmp/oveja/response | htmlq 'article' | htmlq a -a href | awk '{print "https://monoschino2.com/" $1}' >/tmp/oveja/anime_name
			cat /tmp/oveja/response | htmlq 'img.skeleton' -a alt > /tmp/oveja/anime_list
			if [[ $(< /tmp/oveja/response) =~ "p=2" ]]; then
				curl -s -A "$user_agent" "https://monoschino2.com/directorio/anime?p=2&q=$1" -o/tmp/oveja/response; wait
				cat /tmp/oveja/response | htmlq 'article' | htmlq a -a href | awk '{print "https://monoschino2.com/" $1}' >>/tmp/oveja/anime_name
				cat /tmp/oveja/response | htmlq 'img.skeleton' -a alt >> /tmp/oveja/anime_list
			fi
			anime_name=$(cat /tmp/oveja/anime_list | nl -w 1 | fzf --reverse --cycle --prompt "Selecciona un anime: ")
			anime_link=$(sed -n "$(echo "$anime_name" | cut -f1)p" /tmp/oveja/anime_name)
			anime_caps=$(curl -s -A "$user_agent" "$anime_link" | htmlq 'button.mt-2' -t | tail -n1 | awk '{print $NF}')
			if [ $anime_caps -eq 0 ]; then
				echo -e "${red}Este anime no tiene ningun capitulo publicado. Verifica en MyAnimeList o Anilist para cerciorarte de esto, o reportalo como falla en github.com/user/issues/${def}"; exit 2
			fi
			anime_name="${anime_link##*/}"
			select_cap=$(seq 1 $anime_caps | fzf --reverse --cycle --prompt "Selecciona un capitulo: ")
			curl -s -A "$user_agent" "https://monoschino2.com/ver/${anime_name}-${select_cap}" -o/tmp/oveja/response; wait
			paste <(cat /tmp/oveja/response | grep 'span class="icon' -A1 | grep "<span>" | htmlq -t | sed 's/\ //g' | grep -v "^$") <(cat /tmp/oveja/response | grep 'tabsArray\[' | awk '{print $10}' FS="'" | grep -v '^$' | awk '{print "https" $NF}' FS='https') -d ' ' > /tmp/oveja/mirror
			mirror=$(cat /tmp/oveja/mirror | fzf --reverse --cycle --prompt "Selecciona un mirror: ")
			play_anime "$(echo $mirror | awk '{print $1}')" "$(echo $mirror | awk '{print $2}')" "$anime_name" "$select_cap" "$anime_caps" "$frontend"
			exit 0
    	;;
		"AnimeFLV")
			anime_name=$(curl -s -A "$user_agent" "https://www4.animeflv.net/browse?q=$1" | htmlq 'a.Vrnmlk' -a href | awk '{print $NF}' FS='/' | fzf --reverse --cycle --prompt "Seleciona un anime: ")
			anime_caps=$(curl -s -A "$user_agent" "https://www4.animeflv.net/anime/$anime_name" | grep "var episodes " | awk '{print $1}' FS=']' | awk '{print $3}' FS='[' | awk '{print $1}' FS=',')
			if [ $anime_caps -eq 0 ]; then
				echo -e "${red}Este anime no tiene ningun capitulo publicado. Verifica en MyAnimeList o Anilist para cerciorarte de esto, o reportalo como falla en github.com/user/issues/${def}"; exit 2
			fi
			select_cap=$(seq 1 $anime_caps | fzf --reverse --cycle --prompt "Selecciona un capitulo: ")
			curl -s -A "$user_agent" "https://www4.animeflv.net/ver/${anime_name}-${select_cap}" | grep "var videos = {" | sed 's/        var videos = //; s/..$//' | jq -r '.SUB[] | "\(.title)\t\(.code)"' | nl -w1 -s ' ' > /tmp/oveja/mirror
			mirror=$(cat /tmp/oveja/mirror | fzf --reverse --cycle --prompt "Seleccione un mirror: ")
			play_anime "$(echo $mirror | awk '{print $2}')" "$(echo $mirror | awk '{print $NF}')" "$anime_name" "$select_cap" "$anime_caps" "$frontend"
			exit 0
        ;;
	    "Katanime")
	    	echo -e "${red}Actualmente estoy trabajando en esta opcion...${def}"; exit 2
        ;;
    	"TioAnime")
    		anime_name=$(curl -s -A "$user_agent" "https://tioanime.com/directorio?q=$1" | htmlq 'article.anime' | htmlq a -a href | awk '{print $NF}' FS='/' | fzf --reverse --cycle --prompt "Selecciona un anime: ")
    		anime_caps=$(curl -s -A "$user_agent" "https://tioanime.com/anime/$anime_name" | grep "var episodes " | awk '{print $1}' FS=',' | awk '{print $NF}' FS='[' )
    		if [ $anime_caps -eq 0 ];then
    			echo "${red}Este anime no tiene ningun capitulo publicado. Verifica en MyAnimeList o Anilist para cerciorarte de esto, o reportalo como falla en github.com/user/issues/${def}"; exit 2
    		fi
    		select_cap=$(seq 1 $anime_caps | fzf --reverse --cycle --prompt "Seleccione un capitulo: ")
    		curl -s -A "$user_agent" "https://tioanime.com/ver/${anime_name}-${select_cap}" | grep "var videos" | sed 's/    var videos = //; s/..$//' | jq -r '.[] | "\(.[0]) \(.[1])"' | nl -w 1 -s ' ' > /tmp/oveja/mirror
    		mirror=$(cat /tmp/oveja/mirror| fzf --reverse --cycle --prompt "Seleccione un mirror: ")
    		play_anime "$(echo $mirror | awk '{print $2}')" "$(echo $mirror | awk '{print $NF}')" "$anime_name" "$select_cap" "$anime_caps" "$frontend"
    		exit 0
        ;;
    	*)
        echo "${red}Unknow Frontend!${def}"; exit 1;;
	esac
}

function play_anime(){
	echo "$6: $3 $4" >> $HOME/.config/oveja/logs.txt
	echo -e "${bold}Obteniendo el link...${def}"
	case "$1" in
		"Mediafire")
			fix_url=${2/:\/\//:\/\/www.}
			index_link=$(curl -s -A "$user_agent" "$fix_url" | htmlq 'a.popsok' -a href)
			if [ "$index_link" == "" ]; then
				echo -e "${red}404! El link esta caido, prueba otro mirror/frontend${def}"; sleep 2
				anime_options "$1" "$2" "$3" "$4" "$5" "$6"
			fi
			case "$player" in
				"mpv")
    				mpv --user-agent="$user_agent" "$index_link" &>/dev/null &
        		;;
        		"vlc")
    				vlc --http-user-agent="$user_agent" "$index_link" &>/dev/null &
        		;;
    			"ffplay")
    				ffplay -headers "User-Agent: $user_agent"$'\r\n' "$index_link" &>/dev/null &
    			;;
    			*)
    				echo -e "${red}$play no esta soportado${def}"; exit 4
    			;;
    		esac
			echo -e "${bold}Reproduciendo...${def}"; sleep 1.2
			anime_options "$1" "$2" "$3" "$4" "$5" "$6" "$index_link"
			exit 0
		;;
		"Mega" | "MEGA")
			echo -e "${bold}Mega${def} no esta soportado para descarga directa ni reproduccion directa, debes descargarlo/verlo desde su propia pagina.\nDeseas abrir tu Browser por defecto con este link? -> ${bold}$2${def}"
			abrir_navegador=$(echo -e "Si\nNo" | fzf --height 5)
			if [ "$abrir_navegador" == "Si" ]; then xdg-open "$2"; fi
			anime_options "$1" "$2" "$3" "$4" "$5" "$6" "0"
			exit 0
		;;
		"Streamwish" | "SW")
			curl -s -A "$user_agent" "$2" -I >/tmp/oveja/response; wait
			redirect_link=$(cat /tmp/oveja/response | grep 'location' | awk '{print $2}' | sed 's/\r//')
			referer=$(cat /tmp/oveja/response | grep "location" | awk '{print $NF}' | awk '{print $1}' FS="embed" | awk '{print $1}' FS="e/")
			master_link=$(curl -s -H "Referer: https://streamwish.to" -H "User-Agent: $user_agent" "$redirect_link" | grep "eval" | htmlq script -t | grep -v '^$' | js-beautify | grep "master.m3u8" | awk '{print $4}' FS='"' | sed 's/master.m3u8\//master.m3u8/' | grep "^http")
			index=$(curl -s -H "Referer: $referer" -H "User-Agent: $user_agent" "$master_link" | awk NR==3)
			base="${master_link%master.m3u8*}"
			index_link="${base}${index}"
			if [ "$index_link" == "" ]; then
				echo -e "${red}404! El link esta caido, prueba otro mirror/frontend${def}"; sleep 2
				anime_options "$1" "$2" "$3" "$4" "$5" "$6" "$index_link"
			fi
			case "$player" in
				"mpv")
    				mpv --http-header-fields="Referer: $referer" --user-agent="$user_agent" "$index_link" &>/dev/null &
        		;;
        		"vlc")
    				vlc --http-referrer="$referer" --http-user-agent="$user_agent" "$index_link" &>/dev/null &
        		;;
    			"ffplay")
    				ffplay -headers "Referer: $referer"$'\r\n'"User-Agent: $user_agent"$'\r\n' "$index_link" &>/dev/null &
    			;;
    			*)
    				echo -e "${red}$play no esta soportado${def}"; exit 4
    			;;
    		esac
			#anime_options MIRROR LINK_MIRROR NOMBRE_ANIME CAPITULO_ANIME CAPITULOS_TOTALES FRONTEND
			echo -e "${bold}Reproduciendo...${def}"; sleep 1.2
			anime_options "$1" "$2" "$3" "$4" "$5" "$6" "$index_link"
			exit 0
		;;
		"VOE" | "Voex")
			echo -e "${bold}VOE${def} no esta soportado para descarga directa ni reproduccion directa, debes descargarlo/verlo desde su propia pagina.\nDeseas abrir tu Browser por defecto con este link? -> ${bold}$2${def}"
			abrir_navegador=$(echo -e "Si\nNo" | fzf --height 5)
			if [ "$abrir_navegador" == "Si"]; then xdg-open "$2"; fi
			exit 4
		;;
		"Vidhide")
			curl -s -A "$user_agent" "$2" -I >/tmp/oveja/response; wait
			redirect_link=$(cat /tmp/oveja/response | grep 'location' | awk '{print $2}' | sed 's/\r//')
			referer=$(cat /tmp/oveja/response | grep "location" | awk '{print $NF}' | awk '{print $1}' FS="embed" | awk '{print $1}' FS="e/")
			master_link=$(curl -s "$redirect_link" -A "$user_agent" | grep "master" | js-beautify | grep "master.txt" | awk '{print $4}' FS='"')
