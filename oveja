        		"vlc")
    				vlc --http-referrer="https://www.yourupload.com/" --http-user-agent="$user_agent" "$index_link" &>/dev/null &
        		;;
    			"ffplay")
    				ffplay -headers "Referer: https://www.yourupload.com/"$'\r\n'"User-Agent: $user_agent"$'\r\n' "$index_link" &>/dev/null &
    			;;
    			*)
    				echo -e "${red}$play no esta soportado${def}"; exit 4
    			;;
    		esac
			echo -e "${bold}Reproduciendo...${def}"; sleep 1.2
			anime_options "$1" "$2" "$3" "$4" "$5" "$6" "$index_link"
			exit 0
		;;
		"Netu" | "Okru" | "Fembed" | "HQQ")
			echo -e "${red}Usualmente los links de Netu, Okru, Fembed, Hqq estan caidos. No ocupes estas opciones, solo los dejo por si en un futuro funcionan FF${def}"
			exit 4
		;;
		"HLS")
			index_link=${2/\/play\//\/m3u8\/}
			if [ "$index_link" == "" ]; then
				echo -e "${red}404! El link esta caido, prueba otro mirror/frontend${def}"; sleep 2
				anime_options "$1" "$2" "$3" "$4" "$5" "$6" "$index_link"
			fi
			case "$player" in
				"mpv")
    				mpv --user-agent="$user_agent" "$index_link" &>/dev/null &
